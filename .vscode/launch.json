{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CLI: Запуск Release (без отладки)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/Cli/Cli.exe",
            "args": ["127.0.0.1 9002", "--path /"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "externalTerminal",
            "preLaunchTask": "CMake: build"  // Собираем перед запуском
        },
        {
            "name": "CLI: Отладка Release (с отладкой)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/Cli/Cli.exe",
            "args": ["127.0.0.1 9002", "--path /"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "externalTerminal",
            "preLaunchTask": "CMake: build"
        },
        {
            "name": "Server: Запуск Release (без отладки)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/EDS_serverNew/eds_server_new_mediasoup_app.exe",
            "args": ["--server"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "externalTerminal",
            "preLaunchTask": "CMake: build"
        },
        {
            "name": "Server: Отладка Release (с отладкой)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/EDS_serverNew/eds_server_new_mediasoup_app.exe",
            "args": ["--server"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "externalTerminal",
            "preLaunchTask": "CMake: build"
        }
    ]
}
